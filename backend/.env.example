# Required for AI Agent node + Copilot
  GOOGLE_API_KEY=

  # Optional integrations (nodes degrade gracefully when missing)
  SLACK_WEBHOOK_URL=
  GMAIL_CLIENT_SECRET=
  NOTION_API_KEY=
  MCP_SERVER_URL=
  GITHUB_TOKEN=

  # Optional CORS allowlist (comma-separated). Default "*" in dev.
  ALLOWED_ORIGINS=*
  